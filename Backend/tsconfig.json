{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "types": ["node"],

  },

  "include": [
    "src",
    "prisma.config.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}